{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/integration-api-guide",
      "destination": "/integration-api-guide.md"
    },
    {
      "source": "/integration-api-guide/",
      "destination": "/integration-api-guide.md"
    }
  ]
}
